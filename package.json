{
  "name": "eris-themes",
  "displayName": "Eris Themes",
  "description": "Comfortable & Pleasant Color Scheme for Visual Studio Code",
  "version": "1.0.0",
  "publisher": "eriscrypt",
  "author": "eriscrypt (eriscrypt@gmail.com)",
  "homepage": "https://github.com/eriscrypt/eris-themes-vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/eriscrypt/eris-themes-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/eriscrypt/eris-themes-vscode/issues"
  },
  "license": "MIT",
  "keywords": [
    "green",
    "theme"
  ],
  "galleryBanner": {
    "color": "#2f383e",
    "theme": "dark"
  },
  "categories": [
    "Themes"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "main": "dist/index-client.js",
  "browser": "dist/index-web.js",
  "contributes": {
    "themes": [
      {
        "label": "Eris Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/eris-dark.json"
      },
      {
        "label": "Eris Light",
        "uiTheme": "vs",
        "path": "./themes/eris-light.json"
      },
      {
        "label": "Eris Dark Vibrant",
        "uiTheme": "vs-dark",
        "path": "./themes/eris-dark-vibrant.json"
      },
      {
        "label": "Eris Light Vibrant",
        "uiTheme": "vs",
        "path": "./themes/eris-light-vibrant.json"
      }
    ],
    "configuration": {
      "title": "Eris Themes",
      "properties": {
        "eris.darkContrast": {
          "type": "string",
          "default": "medium",
          "description": "Background contrast for the dark variant.",
          "enum": [
            "soft",
            "medium",
            "hard"
          ]
        },
        "eris.lightContrast": {
          "type": "string",
          "default": "medium",
          "description": "Background contrast for the light variant.",
          "enum": [
            "soft",
            "medium",
            "hard"
          ]
        },
        "eris.darkWorkbench": {
          "type": "string",
          "default": "material",
          "description": "Workbench style for the dark variant.",
          "enum": [
            "material",
            "flat",
            "high-contrast"
          ]
        },
        "eris.lightWorkbench": {
          "type": "string",
          "default": "material",
          "description": "Workbench style for the light variant.",
          "enum": [
            "material",
            "flat",
            "high-contrast"
          ]
        },
        "eris.darkCursor": {
          "type": "string",
          "default": "white",
          "description": "The cursor color in the dark variant.",
          "enum": [
            "white",
            "red",
            "orange",
            "yellow",
            "green",
            "aqua",
            "blue",
            "purple"
          ]
        },
        "eris.lightCursor": {
          "type": "string",
          "default": "black",
          "description": "The cursor color in the light variant.",
          "enum": [
            "black",
            "red",
            "orange",
            "yellow",
            "green",
            "aqua",
            "blue",
            "purple"
          ]
        },
        "eris.darkSelection": {
          "type": "string",
          "default": "grey",
          "description": "The background color of selected text in the dark variant.",
          "enum": [
            "grey",
            "red",
            "orange",
            "yellow",
            "green",
            "aqua",
            "blue",
            "purple"
          ]
        },
        "eris.lightSelection": {
          "type": "string",
          "default": "grey",
          "description": "The background color of selected text in the light variant.",
          "enum": [
            "grey",
            "red",
            "orange",
            "yellow",
            "green",
            "aqua",
            "blue",
            "purple"
          ]
        },
        "eris.italicKeywords": {
          "type": "boolean",
          "default": false,
          "description": "Italicize keywords or not."
        },
        "eris.italicComments": {
          "type": "boolean",
          "default": true,
          "description": "Italicize comments or not."
        },
        "eris.diagnosticTextBackgroundOpacity": {
          "type": "string",
          "default": "0%",
          "markdownDescription": "The opacity of the background color of [diagnostic text](https://code.visualstudio.com/updates/v1_52#_error-background-colors).",
          "enum": [
            "0%",
            "12.5%",
            "25%",
            "37.5%",
            "50%"
          ]
        },
        "eris.highContrast": {
          "type": "boolean",
          "default": false,
          "description": "Whether to add an additional border around items across the UI to increase the contrast."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "clean": "rimraf dist",
    "compile:ts": "tsc",
    "compile:themes": "node dist/hook/generateThemes.js",
    "compile": "npm run clean && npm run compile:ts && npm run compile:themes",
    "package": "vsce package",
    "lint": "eslint . --ext .ts",
    "browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. .",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.ts": "eslint --fix",
    "*.{js,json,md}": "prettier --write"
  },
  "engines": {
    "vscode": "^1.55.0"
  },
  "devDependencies": {
    "@types/node": "18.11.14",
    "@types/vscode": "1.55.0",
    "@typescript-eslint/eslint-plugin": "5.46.1",
    "@typescript-eslint/parser": "5.46.1",
    "@vscode/test-web": "0.0.33",
    "@vscode/vsce": "^2.15.0",
    "eslint": "8.29.0",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-prettier": "4.2.1",
    "husky": "8.0.2",
    "lint-staged": "13.1.0",
    "prettier": "2.8.1",
    "rimraf": "3.0.2",
    "typescript": "4.9.4"
  }
}
